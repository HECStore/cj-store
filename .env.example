# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed as a template.
# Loaded automatically at startup via `dotenvy` (see src/main.rs).
# Real process env vars take precedence over entries here.

# Anthropic API key — referenced from data/config.json -> chat.api_key_env
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME
# The env-var name above is configurable via `chat.api_key_env` in data/config.json
# (default `ANTHROPIC_API_KEY`); if you rename it there, rename it here too.

# Override default log level (default is `info`); e.g. RUST_LOG=cj_store=debug
