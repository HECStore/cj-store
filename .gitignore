/target
/data

# Secrets — keep this list exhaustive. `.env*` covers `.env.local`,
# `.env.backup`, etc. The additional entries below catch direnv files
# (`.envrc`) and dotenv variants that don't start with `.env`.
.env
.env.*
!.env.example
.envrc
*.envrc
dotenv
.dotenv
# Cargo registry tokens — only credential files are excluded; the rest of
# .cargo/ (notably config.toml) is tracked normally.
.cargo/credentials
.cargo/credentials.toml

# Claude Code
.claude/settings.local.json

# IDEs
.idea/
.vscode/
*.iml

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor backup/swap
*.swp
*~
*.bak
# Atomic-write leftovers (see src/fsutil.rs::write_atomic)
*.tmp

# Merge/patch artifacts
*.orig
*.rej

# Profiling artifacts
flamegraph.svg
perf.data*

# Rust tooling artifacts
*.rs.bk
*.profraw
*.profdata
